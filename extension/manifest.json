{
  "manifest_version": 3,
  "name": "HNTR Flow Bridge",
  "version": "1.4.0",
  "description": "Enables image generation in HNTR Automation by automating the Flow API call from a dedicated labs.google/flow tab (reCAPTCHA best-effort + batchGenerateImages)",
  "permissions": ["scripting", "tabs"],
  "host_permissions": [
    "https://labs.google/*",
    "https://hntr-automation-production.up.railway.app/*",
    "http://localhost:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://hntr-automation-production.up.railway.app/*",
        "http://localhost:*/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
